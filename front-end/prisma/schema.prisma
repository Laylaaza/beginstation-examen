// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}



model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    CategoryStatus @default(ACTIEF)
  products  Product[]
  createdAt DateTime @default(now())
}

enum CategoryStatus {
  ACTIEF
  DRAFT
  INACTIEF
}



model Product {
  id             Int              @id @default(autoincrement())
  name           String
  description    String?
  price          Float
  imageUrl       String?
  imageData      Bytes?           @db.LongBlob
  imageMime      String?
  status         ProductStatus
  category       Category         @relation(fields: [categoryId], references: [id])
  categoryId     Int
  specifications Specification[]
  createdAt      DateTime         @default(now())
}

model Specification {
  id        Int     @id @default(autoincrement())
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id])
  productId Int
}

enum ProductStatus {
  ACTIEF
  DRAFT
  INACTIEF
}
